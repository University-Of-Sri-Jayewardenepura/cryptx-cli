# ── Appwrite ─────────────────────────────────────────────────────────────────
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=

# ── Database ──────────────────────────────────────────────────────────────────
APPWRITE_DATABASE_ID=

# ── Collections ───────────────────────────────────────────────────────────────
APPWRITE_CTF_COLLECTION_ID=
APPWRITE_SCHOOL_HACKATHON_COLLECTION_ID=
APPWRITE_UNIVERSITY_HACKATHON_COLLECTION_ID=
APPWRITE_DESIGNATHON_COLLECTION_ID=
APPWRITE_MERCH_COLLECTION_ID=

# ── Storage Buckets ───────────────────────────────────────────────────────────
APPWRITE_CTF_BUCKET_ID=
APPWRITE_HACKATHON_SCHOOL_BUCKET_ID=
APPWRITE_HACKATHON_UNIVERSITY_BUCKET_ID=
APPWRITE_DESIGNATHON_BUCKET_ID=
APPWRITE_MERCH_BUCKET_ID=

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Primary email delivery — required for confirmation emails and custom compose.
RESEND_API_KEY=re_...

RESEND_API_KEY=re_dQNcdnaW_8mpxUP3ZeiB7TdfNWcBWt8nx

# ── WAHA (WhatsApp HTTP API) ──────────────────────────────────────────────────
# Set WAHA_BASE_URL to enable group-membership checks in the detail view.
# Leave empty to disable (no checks are performed and no errors are shown).
WAHA_BASE_URL=
WAHA_API_KEY=
WAHA_SESSION=

# WhatsApp group IDs for each event (format: 120363XXXXXXXXXX@g.us)
WAHA_CTF_GROUP_ID=
WAHA_SCHOOL_HACKATHON_GROUP_ID=
WAHA_UNIVERSITY_HACKATHON_GROUP_ID=
WAHA_DESIGNATHON_GROUP_ID=
